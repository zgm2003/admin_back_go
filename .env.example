# admin_back_go local environment template.
# Copy to .env for local development only. Never commit real secrets.

APP_NAME=admin-api
APP_ENV=local
HTTP_ADDR=:8080
HTTP_READ_HEADER_TIMEOUT=5s

# Structured runtime logs. slog always writes JSON to stdout; file output uses lumberjack rotation.
LOG_ENABLE_FILE=true
LOG_DIR=runtime/logs
LOG_FILE_NAME=admin-api.log
LOG_API_FILE_NAME=admin-api.log
LOG_WORKER_FILE_NAME=admin-worker.log
LOG_MAX_TAIL_LINES=2000
LOG_ALLOWED_EXTENSIONS=.log
LOG_FILE_MAX_SIZE_MB=64
LOG_FILE_MAX_BACKUPS=7
LOG_FILE_MAX_AGE_DAYS=14
LOG_FILE_COMPRESS=true

# Preferred Go DSN. If empty, config.Load builds MYSQL_DSN from the legacy DB_* variables below.
MYSQL_DSN=
MYSQL_MAX_OPEN_CONNS=20
MYSQL_MAX_IDLE_CONNS=10
MYSQL_CONN_MAX_LIFETIME=1h

# Legacy PHP-compatible DB variables. Keep values aligned with E:\admin\admin_back\.env when running against the old database.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=admin
DB_USERNAME=root
DB_PASSWORD=

# Preferred Redis addr. If empty, config.Load builds REDIS_ADDR from REDIS_HOST/REDIS_PORT.
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# Legacy PHP-compatible Redis variables.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Token/session infrastructure settings. TOKEN_PEPPER must match the legacy PHP .env value.
# Business token TTLs are stored in auth_platforms.access_ttl / auth_platforms.refresh_ttl, not env.
TOKEN_PEPPER=
TOKEN_REDIS_PREFIX=token:
TOKEN_REDIS_DB=2
TOKEN_SESSION_CACHE_TTL=30m
TOKEN_SINGLE_SESSION_POINTER_TTL=720h

# AES-GCM vault key for encrypted API keys and upload driver secrets. Must match legacy PHP VAULT_KEY when reading existing encrypted rows.
VAULT_KEY=

# Payment runtime. Channel facts live in payment_channels; Alipay credentials/cert paths live in payment_channel_configs.
# private_key_enc stays encrypted in DB; app_cert_path/alipay_cert_path/alipay_root_cert_path point under PAYMENT_CERT_BASE_DIR.
# Cert files are deployment/runtime files and are not committed.
PAYMENT_CERT_BASE_DIR=E:/admin_go/admin_back_go
LEGACY_ADMIN_BACK_ROOT=
PAYMENT_ALIPAY_TIMEOUT=10s
PAYMENT_NOTIFY_LOCK_TTL=30s
PAYMENT_ATTEMPT_LOCK_TTL=30s

# Upload runtime token config. COS STS is disabled by default; upload config CRUD does not require it.
UPLOAD_TOKEN_TTL=15m
UPLOAD_KEY_RANDOM_BYTES=4
COS_STS_ENABLED=false
COS_STS_ENDPOINT=sts.tencentcloudapi.com
COS_STS_REGION=ap-guangzhou

CAPTCHA_TTL=2m
CAPTCHA_REDIS_PREFIX=captcha:slide:
CAPTCHA_SLIDE_PADDING=10

# Phone/email login code settings. Dev mode is local-only; production must wire real mail/SMS before enabling code delivery.
VERIFY_CODE_TTL=5m
VERIFY_CODE_REDIS_PREFIX=auth:verify_code:
VERIFY_CODE_DEV_MODE=true
VERIFY_CODE_DEV_CODE=123456

# Queue worker settings. admin-api does not consume tasks; cmd/admin-worker owns queue consumers.
QUEUE_ENABLED=true
QUEUE_REDIS_DB=3
QUEUE_CONCURRENCY=10
QUEUE_DEFAULT_QUEUE=default
QUEUE_CRITICAL_WEIGHT=6
QUEUE_DEFAULT_WEIGHT=3
QUEUE_LOW_WEIGHT=1
QUEUE_SHUTDOWN_TIMEOUT=10s
QUEUE_DEFAULT_MAX_RETRY=3
QUEUE_DEFAULT_TIMEOUT=30s

# Realtime/WebSocket settings. Use redis when admin-worker and admin-api run as separate processes.
REALTIME_ENABLED=true
REALTIME_PUBLISHER=redis
REALTIME_REDIS_CHANNEL=admin_go:realtime:publish
REALTIME_HEARTBEAT_INTERVAL=25s
REALTIME_SEND_BUFFER=16

# AI runtime timeout governance. Online stream max/idle timeout and stale-run cleanup are separate.
AI_CHAT_STREAM_MAX_DURATION=5m
AI_CHAT_STREAM_IDLE_TIMEOUT=60s
AI_RUN_STALE_TIMEOUT=15m

# Scheduler settings. Scheduler lives in admin-worker and should enqueue tasks, not run business directly.
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_LOCK_PREFIX=admin_go:scheduler:

# Local Vite frontend CORS defaults are built in; set explicitly for production domains.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,platform,device-id,X-Trace-Id,X-Request-Id
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=12h
